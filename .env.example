# ── Waitlist database ────────────────────────────────────────────────
# Neon serverless Postgres. Any of these keys work; the app tries them
# in order. DATABASE_URL is preferred.
DATABASE_URL="postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/tabby?sslmode=require"
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=

# ── Analytics (PostHog) ──────────────────────────────────────────────
# Client-side — safe to expose, used for in-browser event tracking.
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Server-side — falls back to the NEXT_PUBLIC_* keys above if unset.
# POSTHOG_KEY=
# POSTHOG_HOST=

# ── Help agent (Vercel AI Gateway → Anthropic) ───────────────────────
# If unset, the "Ask Tabby" chat route returns an error and the floating
# widget stays gracefully dormant.
AI_GATEWAY_API_KEY="vckp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Tooling only (not needed at runtime) ─────────────────────────────
# Used by `bun run posthog:setup` to provision events/insights.
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=

# Used by `scripts/export-figma-screens.mjs` to re-pull phone mockups.
# FIGMA_TOKEN=
